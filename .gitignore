# ─────────────────────────────────────────────
# NESTIO — .gitignore
# Tells Git which files to never track or commit
# ─────────────────────────────────────────────


# ── Python / Backend ─────────────────────────
# Virtual environment — never commit this
# It is huge and machine-specific
# Anyone cloning runs: pip install -r requirements.txt
venv/
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Environment variables — NEVER commit secrets
.env
.env.local
.env.production

# Python test cache
.pytest_cache/

# MyPy type checker cache
.mypy_cache/


# ── Node / Frontend ──────────────────────────
# Node modules — never commit this
# It is huge — anyone cloning runs: npm install
node_modules/

# Vite build output — generated files, not source
dist/
build/

# Local environment files
.env.local
.env.development.local
.env.test.local
.env.production.local

# Vite cache
.vite/


# ── IDE / Editor ─────────────────────────────
# VS Code settings — personal preferences
.vscode/
.idea/

# Mac OS system files — useless to everyone else
.DS_Store
Thumbs.db


# ── Logs ─────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*


# ── Database ─────────────────────────────────
# Local SQLite database if used in development
*.db
*.sqlite
*.sqlite3